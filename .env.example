# Application Configuration
APP_NAME=AgentEscala
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
METRICS_ENABLED=true

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Database Configuration
DATABASE_URL=postgresql://agentescala:agentescala@localhost:5432/agentescala

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ADMIN_EMAIL=admin@example.com

# Port bindings for shared Docker hosts
AGENTESCALA_BACKEND_BIND_ADDRESS=127.0.0.1
AGENTESCALA_BACKEND_HOST_PORT=8000
AGENTESCALA_DB_BIND_ADDRESS=127.0.0.1
AGENTESCALA_DB_HOST_PORT=5432
