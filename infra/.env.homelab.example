# Configuração de Deploy em Homelab (CT 102)
COMPOSE_PROJECT_NAME=agentescala
APP_NAME=AgentEscala
APP_VERSION=1.0.0
AGENTESCALA_IMAGE=ghcr.io/mglpsw/agentescala:latest
DEBUG=false
LOG_LEVEL=INFO
METRICS_ENABLED=true

# Database Configuration
POSTGRES_USER=agentescala
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_DB=agentescala
DATABASE_URL=postgresql://agentescala:change-this-secure-password@db:5432/agentescala

# Security
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-characters
ADMIN_EMAIL=admin@agentescala.com

# Publicação segura no CT 102
PUBLIC_DOMAIN=escalas.ks-sm.net
PUBLIC_PORT=9443
PUBLIC_BASE_URL=https://escalas.ks-sm.net:9443
CORS_ALLOW_ORIGINS=https://escalas.ks-sm.net:9443

# Exposição local para NPM ou validação manual
# Use 127.0.0.1 para validação local no host.
# Para proxy reverso em container separado, ajuste para o IP LAN do CT 102 ou 0.0.0.0 após revisar o risco.
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_HOST_PORT=18000

# Isolamento explícito de recursos Docker do AgentEscala
POSTGRES_VOLUME_NAME=agentescala_postgres_data
INTERNAL_NETWORK_NAME=agentescala_internal

# Backup local do banco do AgentEscala
BACKUP_DIR=/root/AgentEscala/infra/backups
