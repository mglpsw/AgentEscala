# Projeto/Imagem
COMPOSE_PROJECT_NAME=agentescala
AGENTESCALA_IMAGE=agentescala:homelab

# Banco Postgres
POSTGRES_USER=agentescala
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=agentescala
POSTGRES_VOLUME_NAME=agentescala_postgres_data

# Rede interna dedicada
INTERNAL_NETWORK_NAME=agentescala_internal

# Backend bind/porta no host CT 102
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_HOST_PORT=18000

# App settings
DATABASE_URL=postgresql://agentescala:CHANGE_ME_POSTGRES_PASSWORD@db:5432/agentescala
SECRET_KEY=CHANGE_ME_SECRET_KEY
DEBUG=false
ADMIN_EMAIL=admin@example.com
LOG_LEVEL=INFO
METRICS_ENABLED=true
CORS_ALLOW_ORIGINS=https://escalas.ks-sm.net:9443

# Publicação via NPM
PUBLIC_DOMAIN=escalas.ks-sm.net
PUBLIC_PORT=9443

# OCR (opcional; defaults seguros já existem no backend)
OCR_API_BASE_URL=https://api.ks-sm.net:9443
OCR_API_TIMEOUT_SECONDS=20
OCR_API_ENABLED=true
OCR_API_VERIFY_SSL=true
